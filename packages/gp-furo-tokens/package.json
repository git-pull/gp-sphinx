{
  "name": "@gp-sphinx/furo-tokens",
  "private": true,
  "version": "0.0.1-alpha.13",
  "description": "Furo CSS custom-property contract as a Zod-validated TypeScript token map and Tailwind v4 plugin",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./plugin": "./src/plugin.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest watch",
    "type-check": "tsc --noEmit",
    "harvest": "node --experimental-strip-types scripts/harvest-from-furo.ts"
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
