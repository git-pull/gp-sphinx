---
import { Font } from 'astro:assets'
import { ClientRouter } from 'astro:transitions'
import type { Document } from '@gp-sphinx/astro/schemas/doctree'
import Footer from '../components/Footer.astro'
import MobileSidebar from '../components/MobileSidebar.astro'
import Sidebar from '../components/Sidebar.astro'
import SiteHead from '../components/SiteHead.astro'
import TableOfContents from '../components/TableOfContents.astro'
import ThemeScript from '../components/ThemeScript.astro'
import TopNav from '../components/TopNav.astro'
import '../styles/global.css'

interface Props {
  title: string
  /**
   * Optional page description used for ``<meta name="description">``,
   * Open Graph, and Twitter unfurl. Defaults to a generic site
   * description when the caller doesn't pass one.
   */
  description?: string
  /**
   * Optional doctree to feed the right-rail in-page TOC. Doc pages
   * pass ``entry.data.tree``; symbol pages omit it (they have their
   * own structured article header).
   */
  tocTree?: Document['tree']
  /**
   * Optional GitHub edit URL rendered as an "Edit this page" link
   * below the main content. Doc pages derive it from the entry's
   * source docname; symbol pages omit it (their source lives in
   * the autodoc'd Python module, not in docs/).
   */
  editUrl?: string
}

const SITE_DESCRIPTION =
  'Shared Sphinx documentation platform — consolidated config, bundled extensions, and a typed Astro renderer.'

const { title, description, tocTree, editUrl } = Astro.props
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString()
const pageDescription = description ?? SITE_DESCRIPTION
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <SiteHead
      title={title}
      description={pageDescription}
      canonicalUrl={canonicalUrl}
    />
    <Font cssVariable="--font-sans" preload />
    <Font cssVariable="--font-mono" />
    <ThemeScript />
    <ClientRouter />
  </head>
  <body class="min-h-screen flex flex-col">
    <TopNav />
    <MobileSidebar />
    <div class="mx-auto flex w-full max-w-7xl flex-1 px-4 py-8">
      <Sidebar />
      <main
        class="gp-sphinx-astro-doc min-w-0 flex-1"
        data-pagefind-body
        data-pagefind-meta={`title:${title}`}
      >
        <slot />
        {editUrl !== undefined && (
          <p
            data-test-id="edit-on-github"
            data-pagefind-ignore
            class="mt-12 border-t border-[color:var(--color-border)] pt-4 text-sm text-[color:var(--color-muted)]"
          >
            <a href={editUrl} class="hover:underline">
              Edit this page on GitHub →
            </a>
          </p>
        )}
      </main>
      <TableOfContents tree={tocTree} />
    </div>
    <Footer />
    <script>
      import { enhanceCodeBlocks } from '../lib/code-copy.ts'
      import { initKeyboardShortcuts } from '../lib/keyboard-shortcuts.ts'

      function setupCodeCopy(): void {
        const main = document.querySelector('main.gp-sphinx-astro-doc')
        if (main !== null) {
          enhanceCodeBlocks(main)
        }
      }

      function focusSearch(): void {
        const input = document.querySelector<HTMLInputElement>(
          'input.pagefind-ui__search-input',
        )
        input?.focus()
      }

      setupCodeCopy()
      // The shortcut binder attaches a single document-level listener
      // — installing it once per page load is enough; ``astro:after-swap``
      // doesn't tear listeners down.
      initKeyboardShortcuts({
        scrollToTop: () => {
          window.scrollTo({ top: 0, behavior: 'smooth' })
        },
        scrollToBottom: () => {
          window.scrollTo({
            top: document.body.scrollHeight,
            behavior: 'smooth',
          })
        },
        focusSearch,
      })
      document.addEventListener('astro:after-swap', setupCodeCopy)
    </script>
  </body>
</html>
