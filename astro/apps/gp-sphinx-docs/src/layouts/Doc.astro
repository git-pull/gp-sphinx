---
import '../styles/global.css'

interface Props {
  title: string
}

const { title } = Astro.props
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <main class="gp-sphinx-astro-doc">
      <slot />
    </main>
  </body>
</html>
