---
/**
 * TopNav — sticky site header. Cycle 33 placeholder; full branding +
 * theme toggle land in cycle 35.
 */
---

<header
  data-test-id="top-nav"
  class="sticky top-0 z-40 border-b border-[color:var(--color-border)] bg-[color:var(--color-bg)]/90 backdrop-blur"
>
  <div class="mx-auto flex h-14 max-w-7xl items-center px-4">
    <a
      href="/"
      class="text-base font-semibold tracking-tight text-[color:var(--color-fg)]"
    >
      gp-sphinx
    </a>
  </div>
</header>
