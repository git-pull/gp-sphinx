---
/**
 * SearchBox — Pagefind default-UI mount point.
 *
 * Pagefind's static index lives at ``/pagefind/`` (generated by the
 * ``postbuild`` script). The default UI module attaches itself to
 * the host element by id; we keep the host visually styled to match
 * the rest of the TopNav and let Pagefind drive the dropdown,
 * keyboard navigation, and result highlighting.
 *
 * The keyboard shortcut module (``../lib/search-shortcut.ts``,
 * TDD'd via vitest) layers two affordances on top: ``/`` to focus
 * the input, ``Escape`` to blur. The Pagefind UI itself adds a
 * native ``Escape``-to-clear behaviour inside the input; ours fires
 * when the input has focus but hasn't been edited.
 *
 * Dev-mode caveat: ``/pagefind/`` only exists after ``pnpm build``.
 * During ``pnpm dev`` the script 404s silently and the box renders
 * as a dead input — acceptable because dev iteration usually
 * doesn't need search; full-build verification covers the live UX.
 */
---

<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />

<div data-test-id="search-box" class="hidden md:block w-64">
  <div
    id="gp-sphinx-search"
    class="gp-sphinx-search"
    data-pagefind-ignore
  ></div>
</div>

<style is:global>
  /* Match the Pagefind default UI to our OKLCH theme tokens. The
   * .pagefind-ui prefix is what @pagefind/default-ui emits; we
   * remap a handful of its CSS variables instead of overriding
   * every selector. */
  .gp-sphinx-search .pagefind-ui {
    --pagefind-ui-scale: 0.85;
    --pagefind-ui-primary: var(--color-fg);
    --pagefind-ui-text: var(--color-fg);
    --pagefind-ui-background: var(--color-bg);
    --pagefind-ui-border: var(--color-border);
    --pagefind-ui-tag: var(--color-code-bg);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 6px;
    --pagefind-ui-image-border-radius: 4px;
    --pagefind-ui-image-box-ratio: 3 / 2;
    --pagefind-ui-font: var(--font-sans);
  }

  .gp-sphinx-search .pagefind-ui__search-input {
    font-size: 0.875rem;
    padding: 0.4rem 0.75rem;
  }

  .gp-sphinx-search .pagefind-ui__drawer {
    position: absolute;
    z-index: 50;
    width: min(28rem, 100vw - 2rem);
    margin-top: 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: var(--color-bg);
    box-shadow: 0 8px 24px rgb(0 0 0 / 0.12);
    padding: 0.5rem;
    max-height: 70vh;
    overflow-y: auto;
  }
</style>

<script>
  // Pagefind's default UI is published as ESM; load it lazily on
  // first paint so the home/symbol pages don't pay the parse cost
  // when search isn't visible.
  import { initSearchShortcut } from '../lib/search-shortcut.ts'

  type PagefindUIInstance = {
    triggerSearch?: (query: string) => void
  }

  type PagefindUIConstructor = new (options: {
    element: string | HTMLElement
    showSubResults?: boolean
    showImages?: boolean
    pageSize?: number
    bundlePath?: string
  }) => PagefindUIInstance

  let booted = false

  async function setup(): Promise<void> {
    if (booted) {
      return
    }
    const host = document.getElementById('gp-sphinx-search')
    if (host === null) {
      return
    }
    const module = (await import('@pagefind/default-ui')) as {
      PagefindUI: PagefindUIConstructor
    }
    new module.PagefindUI({
      element: host,
      showSubResults: true,
      showImages: false,
      pageSize: 10,
      bundlePath: '/pagefind/',
    })
    booted = true
    // The default UI re-renders the input lazily on first focus, so
    // poll briefly for it before installing the keyboard shortcut.
    requestAnimationFrame(() => {
      const input = host.querySelector<HTMLInputElement>(
        'input.pagefind-ui__search-input',
      )
      if (input !== null) {
        initSearchShortcut({ input })
      }
    })
  }

  setup()
  document.addEventListener('astro:after-swap', () => {
    booted = false
    void setup()
  })
</script>
