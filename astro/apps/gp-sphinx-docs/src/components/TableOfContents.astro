---
/**
 * TableOfContents — right-rail in-page navigation built from the
 * ``Document.tree`` of the active doc page.
 *
 * The walking logic lives in ``@gp-sphinx-astro/theme`` (TDD'd via
 * vitest in ``test/render/build-toc.test.ts``); this component is
 * the visual seam. When no ``tree`` prop is passed (e.g. on symbol
 * pages, which have their own structured article header), the
 * component renders nothing so the layout's right column collapses.
 */
import { buildToc } from '@gp-sphinx-astro/theme/render/build-toc'
import type { Document } from '@gp-sphinx-astro/theme/schemas/doctree'

interface Props {
  tree?: Document['tree']
}

const { tree } = Astro.props
const entries = tree === undefined ? [] : buildToc(tree)
---

{
  entries.length > 0 && (
    <aside
      data-test-id="table-of-contents"
      class="hidden xl:block xl:w-56 xl:shrink-0 xl:pl-6"
    >
      <nav class="sticky top-20 max-h-[calc(100vh-6rem)] overflow-y-auto pb-8 text-sm">
        <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-[color:var(--color-muted)]">
          On this page
        </p>
        <ul class="space-y-1">
          {entries.map((entry) => (
            <li class:list={[entry.depth >= 2 && 'pl-3']}>
              <a
                href={`#${entry.id}`}
                class="block rounded px-2 py-0.5 text-[color:var(--color-muted)] hover:bg-[color:var(--color-code-bg)] hover:text-[color:var(--color-fg)]"
              >
                {entry.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>
  )
}
