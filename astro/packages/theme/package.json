{
  "name": "@gp-sphinx/astro",
  "version": "0.0.1-alpha.16",
  "description": "Astro theme components and Zod schemas for the gp-sphinx static site.",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schemas/doctree": "./src/schemas/doctree.ts",
    "./schemas/symbol": "./src/schemas/symbol.ts",
    "./schemas/xref": "./src/schemas/xref.ts",
    "./render/build-toc": "./src/render/build-toc.ts",
    "./render/extract-description": "./src/render/extract-description.ts",
    "./render/highlight-code": "./src/render/highlight-code.ts",
    "./render/render-node": "./src/render/render-node.ts",
    "./render/render-symbol": "./src/render/render-symbol.ts",
    "./render/render-with-highlighting": "./src/render/render-with-highlighting.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "shiki": "^4.0.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
